<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/downloadThumbnailCard"
            android:layout_width="72dp"
            android:layout_height="96dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/downloadThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/app_name"
                android:scaleType="centerCrop" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/downloadTypeIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_type_icon"
            android:contentDescription="@string/app_name"
            android:padding="3dp"
            app:layout_constraintStart_toStartOf="@id/downloadThumbnailCard"
            app:layout_constraintTop_toTopOf="@id/downloadThumbnailCard"
            app:tint="?attr/colorOnSurface" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/downloadMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_more"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintBottom_toBottomOf="@id/downloadStatusRow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/downloadStatusRow"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/downloadTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toStartOf="@id/downloadMore"
            app:layout_constraintStart_toEndOf="@id/downloadThumbnailCard"
            app:layout_constraintTop_toTopOf="@id/downloadThumbnailCard" />

        <TextView
            android:id="@+id/downloadPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:ellipsize="middle"
            android:focusable="true"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintBottom_toTopOf="@id/downloadStatusRow"
            app:layout_constraintEnd_toStartOf="@id/downloadMore"
            app:layout_constraintStart_toEndOf="@id/downloadThumbnailCard" />

        <LinearLayout
            android:id="@+id/downloadStatusRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/downloadThumbnailCard"
            app:layout_constraintEnd_toStartOf="@id/downloadMore"
            app:layout_constraintStart_toEndOf="@id/downloadThumbnailCard">

            <TextView
                android:id="@+id/downloadStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadRetry"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/retry"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minHeight="36dp"
                android:padding="0dp"
                android:visibility="gone"
                app:icon="@drawable/ic_retry"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="?attr/colorPrimary" />

        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/downloadProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/downloadStatusRow"
            app:layout_constraintTop_toBottomOf="@id/downloadThumbnailCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
