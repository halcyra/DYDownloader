<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/previewRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:ignore="Overdraw">

    <FrameLayout
        android:id="@+id/previewMediaContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/previewImagePager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.hhst.dydownloader.widget.AspectRatioVideoView
            android:id="@+id/previewVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/previewControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_preview_scrim_bottom" />

        <LinearLayout
            android:id="@+id/previewBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/previewCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:text="@string/time_zero"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.AppCompatSeekBar
                    android:id="@+id/previewProgressBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:splitTrack="false" />

                <TextView
                    android:id="@+id/previewDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:text="@string/time_zero"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/previewCenterControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/previewRewind"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/rewind"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_rewind_5"
                    app:tint="@android:color/white" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/previewPlayPause"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/play_pause"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_pause"
                    app:tint="@android:color/white" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/previewForward"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/forward"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_forward_5"
                    app:tint="@android:color/white" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/previewClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_preview_overlay"
        android:contentDescription="@string/dialog_cancel"
        android:elevation="2dp"
        android:padding="9dp"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
